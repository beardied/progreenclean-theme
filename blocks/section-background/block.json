{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "progreenclean/section-background",
  "version": "1.0.0",
  "title": "Section Background",
  "category": "progreenclean",
  "icon": "cover-image",
  "description": "Full-width section with customizable background colors",
  "supports": {
    "html": false,
    "align": ["wide", "full"]
  },
  "attributes": {
    "backgroundType": {
      "type": "string",
      "default": "gradient"
    },
    "customBackground": {
      "type": "string",
      "default": ""
    },
    "paddingSize": {
      "type": "string",
      "default": "large"
    },
    "marginTop": {
      "type": "string",
      "default": "0"
    },
    "marginBottom": {
      "type": "string",
      "default": "0"
    }
  },
  "editorScript": "file:./block.js",
  "editorStyle": "file:./editor.css",
  "style": "file:./style.css",
  "render": "file:./block.php"
}
