{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "progreenclean/cta-block",
    "version": "1.0.0",
    "title": "PGC CTA Block",
    "category": "progreenclean",
    "icon": "button",
    "description": "Call-to-action block with optional urgency elements",
    "supports": {"html": false, "align": ["wide", "full"]},
    "attributes": {
        "style": {"type": "string", "default": "boxed"},
        "headline": {"type": "string", "default": "Ready to Get Started?"},
        "description": {"type": "string", "default": ""},
        "primaryCta": {"type": "object", "default": {"text": "Get a Quote", "url": "/get-a-quote/"}},
        "secondaryCta": {"type": "object", "default": null},
        "urgencyText": {"type": "string", "default": ""},
        "backgroundColor": {"type": "string", "default": "primary"},
        "animate": {"type": "boolean", "default": true}
    },
    "render": "file:./render.php"
}
