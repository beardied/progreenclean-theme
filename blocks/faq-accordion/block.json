{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "progreenclean/faq-accordion",
    "version": "1.0.0",
    "title": "PGC FAQ Accordion",
    "category": "progreenclean",
    "icon": "editor-help",
    "description": "Expandable FAQ accordion with schema markup",
    "supports": {"html": false},
    "attributes": {
        "category": {"type": "string", "default": ""},
        "limit": {"type": "number", "default": 0},
        "schemaEnabled": {"type": "boolean", "default": true},
        "animate": {"type": "boolean", "default": true}
    },
    "render": "file:./render.php"
}
