{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "progreenclean/faq-custom",
  "version": "1.0.0",
  "title": "Custom FAQ",
  "category": "progreenclean",
  "icon": "editor-help",
  "description": "Manual FAQ entries with schema markup for SEO",
  "supports": {
    "html": false
  },
  "attributes": {
    "title": {
      "type": "string",
      "default": "Frequently Asked Questions"
    },
    "description": {
      "type": "string",
      "default": ""
    },
    "faqs": {
      "type": "array",
      "default": [],
      "source": "query",
      "selector": ".pgc-faq-item",
      "query": {
        "question": {
          "type": "string",
          "source": "text",
          "selector": ".pgc-faq-item__question"
        },
        "answer": {
          "type": "string",
          "source": "text",
          "selector": ".pgc-faq-item__answer"
        }
      }
    },
    "showSchema": {
      "type": "boolean",
      "default": true
    }
  },
  "editorScript": "file:./block.js",
  "editorStyle": "file:./editor.css",
  "style": "file:./style.css",
  "render": "file:./block.php"
}
