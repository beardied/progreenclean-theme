{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "progreenclean/trust-badge",
    "version": "1.0.0",
    "title": "PGC Trust Badge",
    "category": "progreenclean",
    "icon": "star-filled",
    "description": "Display trust indicators with animated counters",
    "supports": {"html": false},
    "attributes": {
        "icon": {"type": "string", "default": "star"},
        "value": {"type": "string", "default": "4.9"},
        "label": {"type": "string", "default": "Google Rating"},
        "suffix": {"type": "string", "default": "/5"},
        "animate": {"type": "boolean", "default": true}
    },
    "render": "file:./render.php"
}
